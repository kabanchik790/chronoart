# Server
NODE_ENV=production
PORT=3001

# Database (Docker service name = db, not localhost)
DATABASE_URL=postgres://chronoart:yourpassword@db:5432/chronoart
POSTGRES_DB=chronoart
POSTGRES_USER=chronoart
POSTGRES_PASSWORD=yourpassword

# Session
SESSION_SECRET=replace-with-long-random-string

# CORS
CLIENT_ORIGIN=https://yourdomain.com

# Email — вариант 1: Gmail + App Password (production)
# Создать App Password: Google Account → Security → App passwords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email — вариант 2: Mailtrap (тестовый перехватчик для разработки)
# Зарегистрироваться: https://mailtrap.io → Email Testing → SMTP Settings
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_SECURE=false
# SMTP_USER=<mailtrap_username>
# SMTP_PASS=<mailtrap_password>
